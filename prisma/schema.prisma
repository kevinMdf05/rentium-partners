// ==============================================
// RENTIUM PARTNERS — Schéma de base de données
// PostgreSQL via Supabase
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// MODÈLE UTILISATEUR
// ──────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  nom              String
  prenom           String
  email            String    @unique
  telephone        String?
  adresse          String?
  ville            String?
  codePostal       String?
  pays             String    @default("France")
  dateNaissance    DateTime?
  passwordHash     String
  emailVerified    DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  role             Role      @default(CLIENT)
  statut           UserStatut @default(ACTIF)
  image            String?
  codeParrainage   String?   @unique
  parrainId        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  parrain       User?          @relation("Parrainage", fields: [parrainId], references: [id])
  filleuls      User[]         @relation("Parrainage")
  subscription  Subscription?
  properties    Property[]
  documents     Document[]
  payments      Payment[]
  messages      Message[]
  loginLogs     LoginLog[]
  notifications Notification[]
  sessions      Session[]
  accounts      Account[]

  @@index([email])
  @@index([codeParrainage])
}

// ──────────────────────────────────────────────
// NEXTAUTH — SESSIONS & COMPTES
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// ABONNEMENT
// ──────────────────────────────────────────────

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planType             PlanType
  planName             String
  prixMensuel          Float
  statut               SubStatut @default(ACTIVE)
  stripeSubId          String?   @unique
  stripeCustomerId     String?
  dateDebut            DateTime  @default(now())
  dateProchainPaiement DateTime?
  dateFin              DateTime?
  codePromo            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// BIEN IMMOBILIER
// ──────────────────────────────────────────────

model Property {
  id           String       @id @default(cuid())
  userId       String
  typeBien     TypeBien
  nom          String?
  adresse      String
  ville        String
  codePostal   String
  valeurBien   Float?
  regimeFiscal RegimeFiscal
  dateAchat    DateTime?
  loyerMensuel Float?
  superficie   Float?
  nbPieces     Int?
  meuble       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([userId])
}

// ──────────────────────────────────────────────
// DOCUMENT
// ──────────────────────────────────────────────

model Document {
  id            String   @id @default(cuid())
  userId        String
  propertyId    String?
  nomFichier    String
  typeDocument  TypeDoc
  urlFichier    String
  tailleFichier Int?
  annee         Int?
  description   String?
  createdAt     DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([propertyId])
}

// ──────────────────────────────────────────────
// PAIEMENT
// ──────────────────────────────────────────────

model Payment {
  id              String    @id @default(cuid())
  userId          String
  montant         Float
  devise          String    @default("EUR")
  statut          PayStatut
  stripePaymentId String?   @unique
  stripeInvoiceId String?
  description     String?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ──────────────────────────────────────────────
// MESSAGERIE
// ──────────────────────────────────────────────

model Message {
  id         String     @id @default(cuid())
  userId     String
  expediteur Expediteur
  sujet      String
  contenu    String     @db.Text
  lu         Boolean    @default(false)
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ──────────────────────────────────────────────
// LOGS DE CONNEXION
// ──────────────────────────────────────────────

model LoginLog {
  id           String   @id @default(cuid())
  userId       String
  ipAddress    String
  userAgent    String?
  localisation String?
  succes       Boolean
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  titre     String
  message   String
  type      NotifType
  lu        Boolean   @default(false)
  lien      String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lu])
}

// ──────────────────────────────────────────────
// CODES PROMO
// ──────────────────────────────────────────────

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  reductionPourcent Float?
  reductionMontant  Float?
  moisOfferts     Int?
  limiteUtilisation Int?
  utilisations    Int       @default(0)
  actif           Boolean   @default(true)
  dateExpiration  DateTime?
  createdAt       DateTime  @default(now())

  @@index([code])
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  CLIENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatut {
  ACTIF
  INACTIF
  SUSPENDU
}

enum SubStatut {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum PlanType {
  LMNP_1
  LMNP_2
  SCI_IR_1
  SCI_IR_2
}

enum TypeBien {
  APPARTEMENT
  MAISON
  STUDIO
  PARKING
  COMMERCE
}

enum RegimeFiscal {
  LMNP
  SCI_IR
}

enum TypeDoc {
  DECLARATION
  BILAN
  FACTURE
  CONTRAT
  AUTRE
}

enum PayStatut {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum Expediteur {
  CLIENT
  ADMIN
}

enum NotifType {
  INFO
  SUCCES
  WARNING
  ERREUR
  PAIEMENT
  DOCUMENT
}
